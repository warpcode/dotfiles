{
  "general": {
    "preferredEditor": "neovim",
    "previewFeatures": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "mcpServers": {},
  "context": {
    "fileName": [
      "AGENTS.md",
      "CRUSH.md",
      "GEMINI.md",
      "docs/guidelines.md",
      "AI.md",
      ".github/copilot-instructions.md"
    ],
    "includeDirectories": [
      "~/.config/opencode"
    ],
    "loadFromIncludeDirectories": true
  },
  "telemetry": {
    "enabled": false
  }
}
