{
  "secrets": {
    "defaults": {
      "priority": [
        "env",
        "keychain",
        "keepass",
        "cmd"
      ]
    },
    "registry": {
      "OPENAI_API_KEY": {
        "env": "OPENAI_API_KEY",
        "keepass": {
          "path": "AI/OpenAI",
          "attribute": "api_key"
        }
      },
      "ANTHROPIC_API_KEY": {
        "env": "ANTHROPIC_API_KEY",
        "keepass": {
          "path": "AI/Anthropic",
          "attribute": "api_key"
        }
      },
      "GOOGLE_API_KEY": {
        "env": "GOOGLE_API_KEY",
        "keepass": {
          "path": "AI/Google",
          "attribute": "api_key"
        }
      },
      "GROQ_API_KEY": {
        "env": "GROQ_API_KEY",
        "keepass": {
          "path": "AI/Groq",
          "attribute": "api_key"
        }
      },
      "MISTRAL_API_KEY": {
        "env": "MISTRAL_API_KEY",
        "keepass": {
          "path": "AI/Mistral",
          "attribute": "api_key"
        }
      },
      "OPENROUTER_API_KEY": {
        "env": "OPENROUTER_API_KEY",
        "keepass": {
          "path": "KeePassXC-Browser Passwords/OpenRouter",
          "attribute": "api_key_litellm"
        }
      },
      "GEMINI_API_KEY": {
        "env": "GEMINI_API_KEY",
        "keepass": {
          "path": "websites/email/google.main",
          "attribute": "gemini_api_key"
        }
      },
      "NVIDIA_AI_API_KEY": {
        "env": "NVIDIA_AI_API_KEY",
        "keepass": {
          "path": "websites/gaming/NVIDIA",
          "attribute": "api_key_coder"
        }
      },
      "LITELLM_API_KEY": {
        "env": "LITELLM_API_KEY",
        "keychain": "ai/litellm"
      },
      "JIRA_URL": {
        "env": "JIRA_URL",
        "cache": true,
        "ttl": 3600,
        "keepass": {
          "path": "[Jira] Api Token",
          "attribute": "URL"
        },
        "profiles_allow": [
          "work"
        ]
      },
      "JIRA_USER": {
        "env": "JIRA_USER",
        "cache": true,
        "ttl": 3600,
        "keepass": {
          "query": "group:work jira api token",
          "attribute": "UserName"
        },
        "profiles_allow": [
          "work"
        ]
      },
      "JIRA_API_TOKEN": {
        "env": "JIRA_API_TOKEN",
        "cache": true,
        "ttl": 3600,
        "keepass": {
          "path": "[Jira] Api Token",
          "attribute": "Password"
        },
        "profiles_allow": [
          "work"
        ]
      },
      "test_secret": {
        "env": "TEST_ENV",
        "profiles_allow": [
          "work"
        ]
      }
    }
  }
}