{{- /* Expects: dict "group" "group_name" (optional) "exclude_groups" (list of group names) (optional) "context" . */ -}}
{{- $group := "" -}}
{{- if hasKey . "group" -}}
  {{- $group = .group -}}
{{- end -}}
{{- $exclude_groups := list -}}
{{- if hasKey . "exclude_groups" -}}
  {{- $exclude_groups = .exclude_groups -}}
{{- end -}}
{{- $ctx := .context -}}

{{- $is_termux := $ctx.is_termux -}}
{{- $sys_manager := $ctx.sys_manager -}}

{{- $groups := list -}}
{{- if ne $group "" -}}
  {{- $groups = list $group -}}
{{- else -}}
  {{- /* Default deterministic ordering of all groups */ -}}
  {{- range $g := list "system" "integration" "cli" "development" "apps" "ai" -}}
    {{- if not (has $g $exclude_groups) -}}
      {{- $groups = append $groups $g -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- $profile := $ctx.profile -}}
{{- $res := dict -}}
{{- template "profiles/filter.tmpl" (dict "data" $ctx.packages "profile" $profile "result" $res) -}}
{{- $filtered_packages := $res.value -}}
# Code generated by chezmoi. DO NOT EDIT.

{{ template "shell/script_utils.sh.tmpl" . }}

# Ensure local paths are in PATH
export PATH="${HOME}/.local/share/mise/shims:${HOME}/.local/bin:${PATH}"

# Initialize package manager queues
sys_pkgs=()
brew_pkgs=()
brew_cask_pkgs=()
flatpak_pkgs=()
snap_pkgs=()
mise_pkgs=()
npm_pkgs=()
uv_pkgs=()

# Detect installed/available package managers
flatpak_installed=0
if command -v flatpak >/dev/null 2>&1; then
  flatpak_installed=1
fi

snap_installed=0
if command -v snap >/dev/null 2>&1; then
  snap_installed=1
fi

# Detect Mise
mise_bin=""
if command -v mise >/dev/null 2>&1; then
  mise_bin="$(command -v mise)"
elif [ -f "${HOME}/.local/bin/mise" ]; then
  mise_bin="${HOME}/.local/bin/mise"
elif [ -f "/usr/bin/mise" ]; then
  mise_bin="/usr/bin/mise"
fi

# npm and uv will be installed by mise, so we assume they are available if needed
npm_installed=1
uv_installed=1

# Compile lists of packages for each package manager based on priority
{{- range $g := $groups }}
  {{- range $pkg := index $filtered_packages $g }}
# Package: {{ $pkg.name }}
if false; then :
{{- if eq $ctx.chezmoi.os "darwin" }}
  {{- if hasKey $pkg "npm" }}
elif [ "$npm_installed" -eq 1 ]; then
  {{- range $p := splitList " " $pkg.npm }}{{ if ne $p "" }}
  npm_pkgs+=("{{ $p }}")
  {{- end }}{{ end }}
  {{- end }}
  {{- if hasKey $pkg "uv" }}
elif [ "$uv_installed" -eq 1 ]; then
  {{- range $p := splitList " " $pkg.uv }}{{ if ne $p "" }}
  uv_pkgs+=("{{ $p }}")
  {{- end }}{{ end }}
  {{- end }}
  {{- if hasKey $pkg "mise" }}
elif [ -n "$mise_bin" ]; then
  {{- range $p := splitList " " $pkg.mise }}{{ if ne $p "" }}
  mise_pkgs+=("{{ $p }}")
  {{- end }}{{ end }}
  {{- end }}
  {{- if hasKey $pkg "brew_cask" }}
elif command -v brew >/dev/null 2>&1; then
  {{- range $p := splitList " " $pkg.brew_cask }}{{ if ne $p "" }}
  brew_cask_pkgs+=("{{ $p }}")
  {{- end }}{{ end }}
  {{- end }}
  {{- if hasKey $pkg "brew" }}
elif command -v brew >/dev/null 2>&1; then
  {{- range $p := splitList " " $pkg.brew }}{{ if ne $p "" }}
  brew_pkgs+=("{{ $p }}")
  {{- end }}{{ end }}
  {{- end }}
{{- else }}
  {{- /* Linux / Termux */ -}}
  {{- if hasKey $pkg "flatpak" }}
elif [ "$flatpak_installed" -eq 1 ]; then
  {{- range $p := splitList " " $pkg.flatpak }}{{ if ne $p "" }}
  flatpak_pkgs+=("{{ $p }}")
  {{- end }}{{ end }}
  {{- end }}
  {{- if hasKey $pkg "snap" }}
elif [ "$snap_installed" -eq 1 ]; then
  snap_pkgs+=("{{ $pkg.snap }}")
  {{- end }}
  {{- if hasKey $pkg "npm" }}
elif [ "$npm_installed" -eq 1 ]; then
  {{- range $p := splitList " " $pkg.npm }}{{ if ne $p "" }}
  npm_pkgs+=("{{ $p }}")
  {{- end }}{{ end }}
  {{- end }}
  {{- if hasKey $pkg "uv" }}
elif [ "$uv_installed" -eq 1 ]; then
  {{- range $p := splitList " " $pkg.uv }}{{ if ne $p "" }}
  uv_pkgs+=("{{ $p }}")
  {{- end }}{{ end }}
  {{- end }}
  {{- if hasKey $pkg "mise" }}
elif [ -n "$mise_bin" ]; then
  {{- range $p := splitList " " $pkg.mise }}{{ if ne $p "" }}
  mise_pkgs+=("{{ $p }}")
  {{- end }}{{ end }}
  {{- end }}
  {{- if and (ne $sys_manager "") (hasKey $pkg $sys_manager) }}
elif true; then
  {{- range $p := splitList " " (index $pkg $sys_manager) }}{{ if ne $p "" }}
  sys_pkgs+=("{{ $p }}")
  {{- end }}{{ end }}
  {{- end }}
{{- end }}
fi
  {{- end }}
{{- end }}

# Install accumulated packages sequentially
# 1. System packages
if [[ ${#sys_pkgs[@]} -gt 0 ]]; then
  info "Installing {{ join " + " $groups }} system packages..."
  {{ if eq $sys_manager "apt" -}}
  run_as_root apt-get install -y -qq "${sys_pkgs[@]}"
  {{- else if eq $sys_manager "dnf" -}}
  dnf_regular=()
  dnf_groups=()
  for pkg in "${sys_pkgs[@]}"; do
    if [[ "$pkg" == @* ]]; then
      dnf_groups+=("${pkg#@}")
    else
      dnf_regular+=("$pkg")
    fi
  done
  if [[ ${#dnf_groups[@]} -gt 0 ]]; then
    run_as_root dnf group install -y "${dnf_groups[@]}"
  fi
  if [[ ${#dnf_regular[@]} -gt 0 ]]; then
    run_as_root dnf install -y "${dnf_regular[@]}"
  fi
  {{- else if eq $sys_manager "pacman" -}}
  run_as_root pacman -S --noconfirm "${sys_pkgs[@]}"
  {{- else if eq $sys_manager "termux" -}}
  pkg install -y "${sys_pkgs[@]}"
  {{- end }}
fi

# 2. Brew packages
if [[ ${#brew_pkgs[@]} -gt 0 ]] && command -v brew >/dev/null 2>&1; then
  info "Installing {{ join " + " $groups }} Homebrew packages..."
  brew install "${brew_pkgs[@]}"
fi

# 3. Brew Cask packages
if [[ ${#brew_cask_pkgs[@]} -gt 0 ]] && command -v brew >/dev/null 2>&1; then
  info "Installing {{ join " + " $groups }} Homebrew casks..."
  brew install --cask "${brew_cask_pkgs[@]}"
fi

# 4. Flatpak packages
if [[ ${#flatpak_pkgs[@]} -gt 0 ]] && command -v flatpak >/dev/null 2>&1; then
  info "Checking Flathub repository configuration..."
  if ! flatpak remote-list | grep -q flathub; then
    info "Configuring Flathub repository..."
    flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo || true
  fi
  info "Installing {{ join " + " $groups }} Flatpak packages..."
  flatpak install -y flathub "${flatpak_pkgs[@]}"
fi

# 5. Snap packages
if [[ ${#snap_pkgs[@]} -gt 0 ]] && command -v snap >/dev/null 2>&1; then
  info "Installing {{ join " + " $groups }} snaps..."
  for pkg in "${snap_pkgs[@]}"; do
    if [[ "$pkg" == *"--classic"* ]]; then
      pkg_name=$(echo "$pkg" | awk '{print $1}')
      run_as_root snap install --classic "$pkg_name"
    else
      run_as_root snap install "$pkg"
    fi
  done
fi

# 6. Mise packages
if [[ ${#mise_pkgs[@]} -gt 0 ]] && [ -n "$mise_bin" ]; then
  info "Installing {{ join " + " $groups }} toolchains via Mise..."
  for pkg in "${mise_pkgs[@]}"; do
    "$mise_bin" use -g "$pkg"
  done
  "$mise_bin" install
fi

# 7. NPM packages
if [[ ${#npm_pkgs[@]} -gt 0 ]]; then
  # Ensure npm is in PATH by adding mise shims explicitly if needed
  export PATH="${HOME}/.local/share/mise/shims:${PATH}"
  if command -v npm >/dev/null 2>&1; then
    info "Installing {{ join " + " $groups }} npm packages..."
    npm install -g "${npm_pkgs[@]}"
  else
    warn "npm not found, skipping npm packages."
  fi
fi

# 8. UV packages
if [[ ${#uv_pkgs[@]} -gt 0 ]]; then
  # Ensure uv is in PATH
  export PATH="${HOME}/.local/share/mise/shims:${PATH}"
  if command -v uv >/dev/null 2>&1; then
    info "Installing {{ join " + " $groups }} tools via uv..."
    for pkg in "${uv_pkgs[@]}"; do
      uv tool install "$pkg" || true
    done
  else
     warn "uv not found, skipping uv tools."
  fi
fi
