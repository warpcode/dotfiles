{{- /* Expects: dict "group" "group_name" "context" . */ -}}
{{- $group := .group -}}
{{- $ctx := .context -}}

{{- $is_termux := false -}}
{{- if and (hasKey $ctx "is_termux") $ctx.is_termux -}}
  {{- $is_termux = true -}}
{{- else if stat "/data/data/com.termux/files/usr/bin" -}}
  {{- $is_termux = true -}}
{{- end -}}

{{- $sys_manager := "" -}}
{{- if eq $ctx.chezmoi.os "darwin" -}}
  {{- $sys_manager = "brew" -}}
{{- else if $is_termux -}}
  {{- $sys_manager = "termux" -}}
{{- else if eq $ctx.chezmoi.os "linux" -}}
  {{- if eq $ctx.chezmoi.osRelease.id "ubuntu" "debian" -}}
    {{- $sys_manager = "apt" -}}
  {{- else if eq $ctx.chezmoi.osRelease.id "fedora" -}}
    {{- $sys_manager = "dnf" -}}
  {{- else if eq $ctx.chezmoi.osRelease.id "arch" -}}
    {{- $sys_manager = "pacman" -}}
  {{- end -}}
{{- end -}}

{{- /* Check if snap is installed on the host */ -}}
{{- $has_snap := false -}}
{{- if lookPath "snap" -}}
  {{- $has_snap = true -}}
{{- end -}}

{{- $hierarchy := list -}}
{{- if eq $ctx.chezmoi.os "darwin" -}}
  {{- $hierarchy = list "brew_cask" "brew" "mise" "npm" -}}
{{- else if $is_termux -}}
  {{- $hierarchy = list "termux" "npm" -}}
{{- else if eq $ctx.chezmoi.os "linux" -}}
  {{- if $has_snap -}}
    {{- $hierarchy = list "flatpak" "snap" "mise" "npm" $sys_manager -}}
  {{- else -}}
    {{- $hierarchy = list "flatpak" "mise" "npm" $sys_manager -}}
  {{- end -}}
{{- end -}}

{{- $profile := $ctx.profile -}}
{{- $sys_pkgs := list -}}
{{- $mise_pkgs := list -}}
{{- $snap_pkgs := list -}}
{{- $flatpak_pkgs := list -}}
{{- $brew_cask_pkgs := list -}}
{{- $npm_pkgs := list -}}

{{- range $pkg := index $ctx.packages $group -}}
  {{- $allowed := true -}}
  {{- if hasKey $pkg "only" -}}
    {{- if ne $pkg.only $profile -}}{{- $allowed = false -}}{{- end -}}
  {{- end -}}
  {{- if hasKey $pkg "not" -}}
    {{- if eq $pkg.not $profile -}}{{- $allowed = false -}}{{- end -}}
  {{- end -}}

  {{- if $allowed -}}
    {{- $resolved_mgr := "" -}}
    {{- $resolved_val := "" -}}
    {{- range $mgr := $hierarchy -}}
      {{- if and (eq $resolved_mgr "") (hasKey $pkg $mgr) -}}
        {{- $resolved_mgr = $mgr -}}
        {{- $resolved_val = index $pkg $mgr -}}
      {{- end -}}
    {{- end -}}

    {{- if ne $resolved_mgr "" -}}
      {{- if eq $resolved_mgr "apt" "dnf" "pacman" "brew" "termux" -}}
        {{- $sys_pkgs = append $sys_pkgs $resolved_val -}}
      {{- else if eq $resolved_mgr "mise" -}}
        {{- $mise_pkgs = append $mise_pkgs $resolved_val -}}
      {{- else if eq $resolved_mgr "snap" -}}
        {{- $snap_pkgs = append $snap_pkgs $resolved_val -}}
      {{- else if eq $resolved_mgr "flatpak" -}}
        {{- $flatpak_pkgs = append $flatpak_pkgs $resolved_val -}}
      {{- else if eq $resolved_mgr "brew_cask" -}}
        {{- $brew_cask_pkgs = append $brew_cask_pkgs $resolved_val -}}
      {{- else if eq $resolved_mgr "npm" -}}
        {{- $npm_pkgs = append $npm_pkgs $resolved_val -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
# Code generated by chezmoi. DO NOT EDIT.

# Helper to run commands as root if needed
run_as_root() {
  if [[ "$(id -u)" -ne 0 ]] && command -v sudo >/dev/null 2>&1; then
    sudo "$@"
  else
    "$@"
  fi
}

# Ensure local paths are in PATH
export PATH="${HOME}/.local/share/mise/shims:${HOME}/.local/bin:${PATH}"

{{ if gt (len $sys_pkgs) 0 }}
echo "Installing {{ $group }} system packages..."
{{ if eq $sys_manager "apt" -}}
run_as_root apt-get install -y -qq {{ join " " $sys_pkgs }}
{{- else if eq $sys_manager "dnf" -}}
{{- $regular := list -}}{{- $groups := list -}}
{{- range $sys_pkgs -}}
  {{- if hasPrefix "@" . -}}{{- $groups = append $groups (trimPrefix "@" .) -}}{{- else -}}{{- $regular = append $regular . -}}{{- end -}}
{{- end -}}
{{ if gt (len $groups) 0 }}run_as_root dnf group install -y {{ join " " $groups }}{{ end }}
{{ if gt (len $regular) 0 }}run_as_root dnf install -y {{ join " " $regular }}{{ end }}
{{- else if eq $sys_manager "pacman" -}}
run_as_root pacman -S --noconfirm {{ join " " $sys_pkgs }}
{{- else if eq $sys_manager "brew" -}}
brew install {{ join " " $sys_pkgs }}
{{- else if eq $sys_manager "termux" -}}
pkg install -y {{ join " " $sys_pkgs }}
{{- end }}
{{ end }}

{{ if gt (len $mise_pkgs) 0 }}
if command -v mise >/dev/null 2>&1; then
  echo "Installing {{ $group }} mise toolchains..."
  {{ range $mise_pkgs -}}
  mise use -g "{{ . }}"
  {{ end -}}
fi
{{ end }}

{{ if gt (len $snap_pkgs) 0 }}
if command -v snap >/dev/null 2>&1; then
  echo "Installing {{ $group }} snaps..."
  {{ range $snap_pkgs -}}
  {{ if hasSuffix "--classic" . -}}
  run_as_root snap install {{ . }}
  {{ else -}}
  run_as_root snap install "{{ . }}"
  {{ end -}}
  {{ end -}}
fi
{{ end }}

{{ if gt (len $flatpak_pkgs) 0 }}
if command -v flatpak >/dev/null 2>&1; then
  echo "Installing {{ $group }} flatpaks..."
  flatpak install -y flathub {{ join " " $flatpak_pkgs }}
fi
{{ end }}

{{ if gt (len $brew_cask_pkgs) 0 }}
if command -v brew >/dev/null 2>&1; then
  echo "Installing {{ $group }} brew casks..."
  brew install --cask {{ join " " $brew_cask_pkgs }}
fi
{{ end }}

{{ if gt (len $npm_pkgs) 0 }}
if command -v npm >/dev/null 2>&1; then
  echo "Installing {{ $group }} npm packages..."
  npm install -g {{ join " " $npm_pkgs }}
fi
{{ end }}
