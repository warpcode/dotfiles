#!/bin/bash
# Setup third-party package manager repositories
# Code generated by chezmoi. DO NOT EDIT.

run_as_root() {
  if [[ "$(id -u)" -ne 0 ]] && command -v sudo >/dev/null 2>&1; then
    sudo "$@"
  else
    "$@"
  fi
}

{{ if eq .chezmoi.os "linux" }}
  {{ if eq .chezmoi.osRelease.id "ubuntu" "debian" }}
    echo "Configuring repositories for Debian/Ubuntu..."
    run_as_root apt-get update -qq
    run_as_root apt-get install -y -qq curl ca-certificates gnupg

    local arch
    arch="$(dpkg --print-architecture)"

    local id="ubuntu"
    local version_codename=""
    if [[ -f /etc/os-release ]]; then
      id="$(grep -E '^ID=' /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "ubuntu")"
      version_codename="$(grep -E '^VERSION_CODENAME=' /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '"' || true)"
    fi

    run_as_root install -m 0755 -d /etc/apt/keyrings
  {{- else if eq .chezmoi.osRelease.id "fedora" }}
    echo "Configuring repositories for Fedora..."
  {{- end }}

  # Include repository setup templates
  {{ template "repositories/github-cli.tmpl" . }}
  {{ template "repositories/mise.tmpl" . }}
  {{ template "repositories/docker.tmpl" . }}
  {{ template "repositories/cursor.tmpl" . }}
  {{ template "repositories/vscode.tmpl" . }}
  {{ template "repositories/antigravity.tmpl" . }}

  {{ if eq .chezmoi.osRelease.id "ubuntu" "debian" -}}
    run_as_root apt-get update -qq
  {{- else if eq .chezmoi.osRelease.id "fedora" -}}
    run_as_root dnf update -y -q
  {{- end }}
{{ end }}
