#!/bin/bash
# Setup third-party package manager repositories
# Code generated by chezmoi. DO NOT EDIT.

{{ template "script_utils.sh.tmpl" . }}

main() {
  # Ensure function is not empty on non-Linux systems
  :

{{ if eq .chezmoi.os "linux" }}
  {{ if or (eq .chezmoi.osRelease.id "ubuntu" "debian") (and (hasKey .chezmoi.osRelease "idLike") (regexMatch "(ubuntu|debian)" .chezmoi.osRelease.idLike)) }}
    info "Configuring repositories for Debian/Ubuntu..."

    local arch
    arch="$(dpkg --print-architecture)"

    local id={{ if or (eq .chezmoi.osRelease.id "ubuntu") (and (hasKey .chezmoi.osRelease "idLike") (regexMatch "ubuntu" .chezmoi.osRelease.idLike)) }}"ubuntu"{{ else }}"debian"{{ end }}
    local version_codename={{ .chezmoi.osRelease.versionCodename | quote }}

    run_as_root install -m 0755 -d /etc/apt/keyrings

  {{- else if eq .chezmoi.osRelease.id "fedora" }}
    info "Configuring repositories for Fedora..."
  {{- end }}

  # Include repository setup templates
  {{ template "repositories/docker.sh.tmpl" . }}
  {{ template "repositories/cursor.sh.tmpl" . }}
  {{ template "repositories/vscode.sh.tmpl" . }}

  {{ template "update_package_manager.sh.tmpl" . }}
{{ end }}
}

main "$@"
