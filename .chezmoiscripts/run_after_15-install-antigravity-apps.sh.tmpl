#!/bin/bash
# Install and update Antigravity 2.0 (Hub) and Antigravity 2.0 IDE
# Code generated by chezmoi. DO NOT EDIT.

{{ template "script_utils.sh.tmpl" . }}

{{ if and (eq .chezmoi.os "linux") (not .is_termux) (eq .profile "default") -}}

# Define constants
OPT_DIR="${HOME}/.local/opt"
BIN_DIR="${HOME}/.local/bin"

_fetch_json() {
  local url="$1"
  curl -fsSL "$url" 2>/dev/null || true
}

_parse_version_and_id() {
  local json_data="$1"
  printf '%s\n' "$json_data" | python3 -c 'import sys, json; r=json.load(sys.stdin)[0]; print(r["version"], r["execution_id"])' 2>/dev/null || true
}

# Fetch latest versions
fetch_latest_metadata() {
  local hub_releases
  local ide_releases
  
  hub_releases=$(_fetch_json "https://antigravity-auto-updater-974169037036.us-central1.run.app/releases")
  ide_releases=$(_fetch_json "https://antigravity-ide-auto-updater-974169037036.us-central1.run.app/releases")

  if [[ -z "$hub_releases" || -z "$ide_releases" ]]; then
    err "Failed to fetch releases metadata from autoupdater servers."
    return 1
  fi

  # Parse Hub version and execution ID
  local hub_metadata
  hub_metadata=$(_parse_version_and_id "$hub_releases")
  local hub_version
  local hub_exec_id
  read -r hub_version hub_exec_id <<< "$hub_metadata"

  # Parse IDE version and execution ID
  local ide_metadata
  ide_metadata=$(_parse_version_and_id "$ide_releases")
  local ide_version
  local ide_exec_id
  read -r ide_version ide_exec_id <<< "$ide_metadata"

  if [[ -z "$hub_version" || -z "$hub_exec_id" || -z "$ide_version" || -z "$ide_exec_id" ]]; then
    err "Failed to parse latest version metadata."
    return 1
  fi

  echo "$hub_version $hub_exec_id $ide_version $ide_exec_id"
}

_is_up_to_date() {
  local target_dir="$1"
  local target_version="$2"
  local current_version=""

  if [[ -f "${target_dir}/.version" ]]; then
    current_version=$(cat "${target_dir}/.version")
  fi

  [[ "${current_version}" == "${target_version}" ]]
}

_download_and_extract() {
  local name="$1"
  local download_url="$2"
  local tmp_archive="$3"
  local tmp_extract="$4"

  if ! curl -fsSL -o "${tmp_archive}" "${download_url}"; then
    err "Failed to download ${name} from ${download_url}"
    return 1
  fi

  if ! tar -xzf "${tmp_archive}" -C "${tmp_extract}"; then
    err "Failed to extract ${name} archive."
    return 1
  fi

  return 0
}

_install_extracted() {
  local tmp_extract="$1"
  local tarball_subdir="$2"
  local target_dir="$3"
  local target_version="$4"
  local binary_name="$5"
  local slug="$6"

  # Clean target directory and move new files
  if [[ -L "${target_dir}" ]]; then
    rm -f "${target_dir}"
    mkdir -p "${target_dir}"
  else
    rm -rf "${target_dir:?}"/*
  fi
  cp -a "${tmp_extract}/${tarball_subdir}/." "${target_dir}/"
  
  # Write version file
  echo "${target_version}" > "${target_dir}/.version"
  
  # Ensure executable permission
  chmod +x "${target_dir}/${binary_name}"

  # Create symlink in bin directory
  mkdir -p "${BIN_DIR}"
  ln -sf "${target_dir}/${binary_name}" "${BIN_DIR}/${slug}"
}

install_app() {
  local name="$1"           # "Antigravity Hub" / "Antigravity IDE"
  local slug="$2"           # "antigravity-hub" / "antigravity-ide"
  local version="$3"        # e.g., "2.0.1"
  local exec_id="$4"        # e.g., "6566078776737792"
  local download_url="$5"   # full download URL
  local tarball_subdir="$6" # e.g., "Antigravity-x64" / "Antigravity IDE"
  local binary_name="$7"    # e.g., "antigravity" / "antigravity-ide"

  local target_dir="${OPT_DIR}/${slug}"
  local target_version="${version}-${exec_id}"

  if _is_up_to_date "${target_dir}" "${target_version}"; then
    success "${name} is already up to date (${version})."
    return 0
  fi

  info "Installing/updating ${name} to ${version}..."
  mkdir -p "${target_dir}"

  local tmp_archive
  tmp_archive=$(mktemp)
  local tmp_extract
  tmp_extract=$(mktemp -d)

  if ! _download_and_extract "${name}" "${download_url}" "${tmp_archive}" "${tmp_extract}"; then
    rm -rf "${tmp_extract}" "${tmp_archive}"
    return 1
  fi

  _install_extracted "${tmp_extract}" "${tarball_subdir}" "${target_dir}" "${target_version}" "${binary_name}" "${slug}"

  rm -rf "${tmp_extract}" "${tmp_archive}"
  success "${name} ${version} installed successfully."
}

main() {
  # Verify curl and python3 are installed
  if ! command -v curl >/dev/null 2>&1; then
    err "curl is required to install Antigravity apps."
    return 1
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    err "python3 is required to parse version information."
    return 1
  fi

  # Retrieve versions
  local metadata
  metadata=$(fetch_latest_metadata)
  if [[ -z "$metadata" ]]; then
    exit 1
  fi

  local hub_version
  local hub_exec_id
  local ide_version
  local ide_exec_id
  
  hub_version=$(echo "$metadata" | awk '{print $1}')
  hub_exec_id=$(echo "$metadata" | awk '{print $2}')
  ide_version=$(echo "$metadata" | awk '{print $3}')
  ide_exec_id=$(echo "$metadata" | awk '{print $4}')

  local hub_url="https://storage.googleapis.com/antigravity-public/antigravity-hub/${hub_version}-${hub_exec_id}/linux-x64/Antigravity.tar.gz"
  local ide_url="https://edgedl.me.gvt1.com/edgedl/release2/j0qc3/antigravity/stable/${ide_version}-${ide_exec_id}/linux-x64/Antigravity%20IDE.tar.gz"

  install_app "Antigravity Hub" "antigravity-hub" "${hub_version}" "${hub_exec_id}" "${hub_url}" "Antigravity-x64" "antigravity"
  install_app "Antigravity IDE" "antigravity-ide" "${ide_version}" "${ide_exec_id}" "${ide_url}" "Antigravity IDE" "antigravity-ide"
}

main "$@"

{{- end }}
