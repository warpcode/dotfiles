# Install Mise tool manager if not already present.
# Code generated by chezmoi. DO NOT EDIT.

{{ template "script_utils.tmpl" . }}

# Ensure local bin is in PATH so we can check if it is already installed
export PATH="${HOME}/.local/bin:${PATH}"

