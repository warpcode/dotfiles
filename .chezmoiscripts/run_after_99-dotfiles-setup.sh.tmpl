{{ template "shell/script_utils.sh.tmpl" . }}

main() {
  local zsh_path
  zsh_path="$(command -v zsh 2>/dev/null)" || return 0

  local dotfiles_init="{{ .chezmoi.sourceDir }}/src/zsh/init.zsh"

  if [[ -f "$dotfiles_init" ]]; then
    info "Running post-apply Zsh hooks..."
    export DOTFILES="{{ .chezmoi.sourceDir }}"
    # We run submodules, recipe configuration, and setup events.
    # We skip 'dotfiles.setup.zshrc' because Chezmoi manages .zshrc now.
    "$zsh_path" -c "source '$dotfiles_init' && \
      dotfiles.setup.submodules && \
      pkg.recipe.configure_all && \
      events.trigger 'dotfiles.setup.first' && \
      events.trigger 'dotfiles.setup'"
  else
    warn "Could not find $dotfiles_init, skipping post-apply Zsh hooks."
  fi
}

main "$@"
