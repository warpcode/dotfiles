#!/bin/bash
# Install desktop/GUI applications for OS: {{ .chezmoi.os }}, Profile: {{ .profile }}

{{- $is_termux := false -}}
{{- if and (hasKey . "is_termux") .is_termux -}}
  {{- $is_termux = true -}}
{{- else if stat "/data/data/com.termux/files/usr/bin" -}}
  {{- $is_termux = true -}}
{{- end -}}

{{- $manager := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
  {{- $manager = "brew" -}}
{{- else if $is_termux -}}
  {{- $manager = "termux" -}}
{{- else if eq .chezmoi.os "linux" -}}
  {{- if eq .chezmoi.osRelease.id "ubuntu" "debian" -}}
    {{- $manager = "apt" -}}
  {{- else if eq .chezmoi.osRelease.id "fedora" -}}
    {{- $manager = "dnf" -}}
  {{- else if eq .chezmoi.osRelease.id "arch" -}}
    {{- $manager = "pacman" -}}
  {{- end -}}
{{- end -}}

{{- $profile := .profile -}}
{{- $os_pkgs := list -}}
{{- $snaps := list -}}
{{- $flatpaks := list -}}
{{- $casks := list -}}

{{- range $pkg := .packages.apps -}}
  {{- $allowed := true -}}
  {{- if hasKey $pkg "only" -}}
    {{- if ne $pkg.only $profile -}}{{- $allowed = false -}}{{- end -}}
  {{- end -}}
  {{- if hasKey $pkg "not" -}}
    {{- if eq $pkg.not $profile -}}{{- $allowed = false -}}{{- end -}}
  {{- end -}}
  {{- if $allowed -}}
    {{- if and $manager (hasKey $pkg $manager) -}}
      {{- $os_pkgs = append $os_pkgs (index $pkg $manager) -}}
    {{- end -}}
    {{- if hasKey $pkg "snap" -}}
      {{- $snaps = append $snaps $pkg.snap -}}
    {{- end -}}
    {{- if and (eq $.chezmoi.os "linux") (hasKey $pkg "flatpak") -}}
      {{- $flatpaks = append $flatpaks $pkg.flatpak -}}
    {{- end -}}
    {{- if and (eq $.chezmoi.os "darwin") (hasKey $pkg "brew_cask") -}}
      {{- $casks = append $casks $pkg.brew_cask -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- if gt (len $os_pkgs) 0 }}
  {{- if eq $manager "apt" }}
    echo "Installing app packages..."
    sudo apt-get install -y -qq {{ join " " $os_pkgs }}
  {{- else if eq $manager "dnf" }}
    echo "Installing app packages..."
    sudo dnf install -y {{ join " " $os_pkgs }}
  {{- else if eq $manager "pacman" }}
    echo "Installing app packages..."
    sudo pacman -S --noconfirm {{ join " " $os_pkgs }}
  {{- else if eq $manager "brew" }}
    echo "Installing Homebrew app packages..."
    brew install {{ join " " $os_pkgs }}
  {{- else if eq $manager "termux" }}
    echo "Installing Termux app packages..."
    pkg install -y {{ join " " $os_pkgs }}
  {{- end }}
{{- end }}

{{- if gt (len $snaps) 0 }}
  if command -v snap >/dev/null; then
    echo "Installing application snaps..."
    {{- range $snaps }}
      sudo snap install {{ . }} || true
    {{- end }}
  fi
{{- end }}

{{- if gt (len $flatpaks) 0 }}
  if command -v flatpak >/dev/null; then
    echo "Installing application flatpaks..."
    flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo || true
    flatpak install -y flathub {{ join " " $flatpaks }}
  fi
{{- end }}

{{- if gt (len $casks) 0 }}
  if command -v brew >/dev/null; then
    echo "Installing macOS Casks..."
    brew install --cask {{ join " " $casks }}
  fi
{{- end }}
