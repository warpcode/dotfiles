{{- $profile := "" -}}
{{- if hasKey . "profile" -}}
  {{- $profile = .profile -}}
{{- else if stdinIsATTY -}}
  {{- $profile = promptChoiceOnce . "profile" "Select profile" (list "default" "work" "phone") -}}
{{- else -}}
  {{- $profile = "default" -}}
{{- end -}}

{{- $is_termux := false -}}
{{- if stat "/data/data/com.termux/files/usr/bin" -}}
  {{- $is_termux = true -}}
{{- end -}}

{{- $sys_manager := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
  {{- $sys_manager = "brew" -}}
{{- else if $is_termux -}}
  {{- $sys_manager = "termux" -}}
{{- else if eq .chezmoi.os "linux" -}}
  {{- if or (eq .chezmoi.osRelease.id "ubuntu" "debian") (and (hasKey .chezmoi.osRelease "idLike") (regexMatch "(ubuntu|debian)" .chezmoi.osRelease.idLike)) -}}
    {{- $sys_manager = "apt" -}}
  {{- else if or (eq .chezmoi.osRelease.id "fedora") (and (hasKey .chezmoi.osRelease "idLike") (regexMatch "fedora" .chezmoi.osRelease.idLike)) -}}
    {{- $sys_manager = "dnf" -}}
  {{- else if or (eq .chezmoi.osRelease.id "arch") (and (hasKey .chezmoi.osRelease "idLike") (regexMatch "arch" .chezmoi.osRelease.idLike)) -}}
    {{- $sys_manager = "pacman" -}}
  {{- end -}}
{{- end -}}

{{- $git_name := "" -}}
{{- if hasKey . "git_name" -}}
  {{- $git_name = .git_name -}}
{{- else if stdinIsATTY -}}
  {{- $git_name = promptStringOnce . "git_name" "Git User Name" -}}
{{- else -}}
  {{- $git_name = "CI Test" -}}
{{- end -}}

{{- $git_email := "" -}}
{{- if hasKey . "git_email" -}}
  {{- $git_email = .git_email -}}
{{- else if stdinIsATTY -}}
  {{- $git_email = promptStringOnce . "git_email" "Git User Email" -}}
{{- else -}}
  {{- $git_email = "ci@example.com" -}}
{{- end -}}

{{- $keepass_db := "" -}}
{{- if hasKey . "keepass_db" -}}
  {{- $keepass_db = .keepass_db -}}
{{- else if stdinIsATTY -}}
  {{- $keepass_db = promptStringOnce . "keepass_db" "KeePass XC Database Path" (joinPath .chezmoi.homeDir ".keepass/Accounts.kdbx") -}}
{{- end -}}

{{- $keepass_installed := false -}}
{{- $keepass_cli := "" -}}
{{- if and $keepass_db (stat $keepass_db) -}}
  {{- $keepass_cli = output "sh" "-c" (printf "%s cli 2>/dev/null || true" (joinPath .chezmoi.sourceDir "bin/df.keepass")) | trim -}}
  {{- if ne $keepass_cli "" -}}
    {{- $keepass_installed = true -}}
  {{- end -}}
{{- end -}}
{{- $llamacpp_arch := "" -}}
{{- if eq .chezmoi.arch "arm64" -}}
  {{- $llamacpp_arch = "arm64" -}}
{{- else if eq .chezmoi.arch "amd64" -}}
  {{- $llamacpp_arch = "x64" -}}
{{- end -}}

{{- $llamacpp_os := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
  {{- $llamacpp_os = "macos" -}}
{{- else if eq .chezmoi.os "linux" -}}
  {{- if $is_termux -}}
    {{- $llamacpp_os = "android" -}}
  {{- else -}}
    {{- $llamacpp_os = "ubuntu" -}}
  {{- end -}}
{{- end -}}

{{- $os := "linux" -}}
{{- if eq .chezmoi.os "darwin" -}}
  {{- $os = "darwin" -}}
{{- else if $is_termux -}}
  {{- $os = "termux" -}}
{{- else if eq .chezmoi.os "linux" -}}
  {{- $id := .chezmoi.osRelease.id -}}
  {{- if eq $id "ubuntu" -}}
    {{- $os = "ubuntu" -}}
  {{- else if eq $id "debian" -}}
    {{- $os = "debian" -}}
  {{- else if or (eq $id "arch") (and (hasKey .chezmoi.osRelease "idLike") (regexMatch "arch" .chezmoi.osRelease.idLike)) -}}
    {{- $os = "archlinux" -}}
  {{- else if or (eq $id "fedora") (and (hasKey .chezmoi.osRelease "idLike") (regexMatch "fedora" .chezmoi.osRelease.idLike)) -}}
    {{- $os = "fedora" -}}
  {{- end -}}
{{- end -}}

{{- $supported_llamacpp := false -}}
{{- if and $llamacpp_os $llamacpp_arch -}}
  {{- if or (ne $llamacpp_os "android") (eq $llamacpp_arch "arm64") -}}
    {{- $supported_llamacpp = true -}}
  {{- end -}}
{{- end -}}

sourceDir = "{{ .chezmoi.sourceDir }}"

[data]
    profile = {{ $profile | quote }}
    is_termux = {{ $is_termux }}
    is_default_linux = {{ and (eq .chezmoi.os "linux") (not $is_termux) (eq $profile "default") }}
    sys_manager = {{ $sys_manager | quote }}
    os_detected = {{ $os | quote }}
    git_name = {{ $git_name | quote }}
    git_email = {{ $git_email | quote }}
    keepass_db = {{ $keepass_db | quote }}
    keepass_installed = {{ $keepass_installed }}
    llamacpp_supported = {{ $supported_llamacpp }}
    llamacpp_os = {{ $llamacpp_os | quote }}
    llamacpp_arch = {{ $llamacpp_arch | quote }}

{{- if $keepass_installed }}
[keepassxc]
    database = {{ $keepass_db | quote }}
    {{- $keepass_cli_parts := splitList " " $keepass_cli }}
    command = {{ first $keepass_cli_parts | quote }}
    args = {{ rest $keepass_cli_parts | toJson }}
{{- end }}
