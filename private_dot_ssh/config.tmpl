# IgnoreUnknown options that may not exist on older SSH versions
# AddKeysToAgent requires OpenSSH 7.2+, UseKeychain is macOS-only
IgnoreUnknown AddKeysToAgent,UseKeychain

AddKeysToAgent yes
PubkeyAuthentication yes
ServerAliveInterval 60
UseKeychain yes

{{- range (index . "hosts" | default (list)) }}
Host {{ .name }}
    HostName {{ .hostname }}
    User {{ .user | default $.chezmoi.username }}
    {{- if .identity_file }}
    IdentityFile {{ .identity_file }}
    {{- end }}
    # Legacy Host Keys for older servers
    HostKeyAlgorithms +ssh-rsa
    # Enable legacy RSA signatures (OpenSSH >= 8.8)
    PubkeyAcceptedAlgorithms +ssh-rsa
{{ end -}}
