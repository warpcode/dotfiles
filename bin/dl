#!/bin/env bash

URL="$1"
SAVETO="$2"

function urldecode() { : "${*//+/ }"; echo -e "${_//%/\\x}"; }

if [ -z "$SAVETO"  ]; then
    SAVETO=$(basename "$(urldecode "$URL")")
fi

exec wget -O "$SAVETO" -q --show-progress --retry-connrefused --waitretry=1 --read-timeout=20 --timeout=15 -t 0 -- "$URL"
