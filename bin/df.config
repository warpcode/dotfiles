#!/usr/bin/env zsh
#
# df.config - Unified configuration management utility.
# Extracted from src/zsh/functions/config.zsh

emulate -LR zsh
setopt ERR_EXIT PIPE_FAIL NO_UNSET WARN_CREATE_GLOBAL EXTENDED_GLOB

zmodload zsh/datetime

# Determine DOTFILES root
0="${${ZERO:-${0:#$ZSH_ARGZERO}}:-${(%):-%N}}"
typeset -r SCRIPT_DIR="${0:A:h}"
export DOTFILES="${DOTFILES:-${0:A:h:h}}"
typeset -r DOTFILES


#######################################
# Print error message to stderr.
# Arguments:
#   All arguments are printed.
# Outputs:
#   Writes error string to stderr.
#######################################
err() {
  print -r -- "df.config: $*" >&2
}

#######################################
# Resolve an asset path.
# Arguments:
#   $1 - Asset type (e.g., configs, templates).
#   $2 - Path to resolve.
# Outputs:
#   Writes absolute path to stdout.
# Returns:
#   0 if found, 1 otherwise.
#######################################
_resolve_path() {
  local type="${1}"
  local path="${2}"

  if [[ -e "${path}" ]]; then
    print -r -- "${path:a:P}"
    return 0
  fi

  if [[ "${type}" == "configs" ]]; then
    local parent_dir="${path:h}"
    local filename="${path:t}"
    local search_dir="assets/configs"
    if [[ "${parent_dir}" != "." ]]; then
      search_dir="${search_dir}/${parent_dir}"
    fi
    local -a resolved_list
    resolved_list=( ${(f)"$("${SCRIPT_DIR}/df.fs" profile list "${search_dir}" "${filename}" 2>/dev/null)"} )
    local resolved=""
    if (( ${#resolved_list} > 0 )); then
      resolved="${resolved_list[1]}"
    fi
    if [[ -n "${resolved}" && -e "${resolved}" ]]; then
      print -r -- "${resolved:a:P}"
      return 0
    fi
  fi

  local full="${DOTFILES}/assets/${type}/${path}"
  if [[ -e "${full}" ]]; then
    print -r -- "${full:a:P}"
    return 0
  fi

  return 1
}

# ---------------------------------------------------------------------------
# Secret Resolver (Unified logic)
# ---------------------------------------------------------------------------

#######################################
# Load and merge secret registries based on profiles.
#######################################
_load_secrets_registry() {
  local -a profile_files=( ${(f)"$("${SCRIPT_DIR}/df.fs" profile list "assets/configs/secrets" "*.json" 2>/dev/null)"} )
  local -a secret_files=()
  local f
  for (( i=${#profile_files[@]}; i>0; i-- )); do
      secret_files+=( "${profile_files[$i]}" )
  done

  if (( ${#secret_files[@]} > 0 )); then
    jq -s 'reduce .[] as $item ({}; . * $item)' "${secret_files[@]}" 2>/dev/null
  else
    echo "{}"
  fi
}

#######################################
# Resolve a secret alias using multi-provider priority.
# Arguments:
#   $1 - Alias name.
#   $2 - (optional) Pre-loaded registry JSON.
#######################################
_resolve_secret_alias() {
  local alias_name="$1"
  local secrets_json="${2:-$(_load_secrets_registry)}"

  local cfg
  cfg="$(print -r -- "${secrets_json}" | jq -c --arg a "${alias_name}" '.[$a]')"

  if [[ "${cfg}" == "null" ]]; then
    # Fallback: check if it's a literal keychain service
    "${SCRIPT_DIR}/df.keychain" get "${alias_name}" 2>/dev/null && return 0
    return 1
  fi

  local priority
  priority=( ${(f)"$(print -r -- "${secrets_json}" | jq -r '.priority // ["env", "keychain", "keepass"] | .[]')"} )

  local p resolved_val=""
  for p in "${priority[@]}"; do
    case "${p}" in
      env)
        local env_var
        env_var="$(print -r -- "${cfg}" | jq -r '.env // empty')"
        if [[ -n "${env_var}" && -v "${env_var}" ]]; then
          resolved_val="${(P)env_var}"
        fi
        ;;
      keychain)
        local _df_svc="$(print -r -- "${cfg}" | jq -r '.keychain // empty')"
        if [[ -n "${_df_svc}" ]]; then
          resolved_val=$("${SCRIPT_DIR}/df.keychain" get "${_df_svc}" 2>/dev/null) || true
        fi
        ;;
      keepass)
        local kp_attr kp_query
        kp_query="$(print -r -- "${cfg}" | jq -r '.keepass.path // .keepass.query // empty')"
        kp_attr="$(print -r -- "${cfg}" | jq -r '.keepass.attribute // "Password"')"

        if [[ -n "${kp_query}" ]]; then
          resolved_val=$("${SCRIPT_DIR}/df.keepass" get "${kp_query}" "${kp_attr}" 2>/dev/null) || true
        fi
        ;;
      cmd)
        local cmd_args
        cmd_args=( ${(f)"$(print -r -- "${cfg}" | jq -r '.cmd // empty | .[]')"} )
        if [[ ${#cmd_args[@]} -gt 0 ]]; then
          resolved_val=$("${cmd_args[@]}" 2>/dev/null) || true
        fi
        ;;
    esac
    [[ -n "${resolved_val}" ]] && break
  done

  if [[ -n "${resolved_val}" ]]; then
    print -nr -- "${resolved_val}"
    return 0
  fi
  return 1
}

# ---------------------------------------------------------------------------
# Resolve Subcommand
# ---------------------------------------------------------------------------

cmd_resolve() {
  local alias_name="${1:-}"
  [[ -z "${alias_name}" ]] && { err "Usage: df.config resolve <ALIAS>"; return 1; }
  _resolve_secret_alias "${alias_name}"
}

# ---------------------------------------------------------------------------
# Block Subcommand
# ---------------------------------------------------------------------------

_usage_block() {
  print -r -- "Usage: df.config block <file> <lead_marker> <tail_marker> <replacement_content>"
}

cmd_block() {
  local -A opts
  zparseopts -E -D -A opts -- h -help

  if (( ${+opts[-h]} || ${+opts[--help]} )); then
    _usage_block
    return 0
  fi

  local file="${1:-}"
  local lead="${2:-}"
  local tail="${3:-}"
  local repl="${4:-}"

  if [[ -z "${file}" || -z "${lead}" || -z "${tail}" || -z "${repl}" ]]; then
    _usage_block
    return 1
  fi

  if [[ ! -f "${file}" ]]; then
    print -r -- "${lead}" > "${file}"
    print -r -- "${repl}" >> "${file}"
    print -r -- "${tail}" >> "${file}"
  elif [[ ! "$(<"${file}")" =~ "${lead}" ]] || [[ ! "$(<"${file}")" =~ "${tail}" ]]; then
    print -r -- "${lead}" >> "${file}"
    print -r -- "${repl}" >> "${file}"
    print -r -- "${tail}" >> "${file}"
  else
    local -a lines=( ${(f)"$(<"${file}")"} )
    local -a new_lines=()
    local block=0
    local line

    for line in "${lines[@]}"; do
      if [[ "${line}" =~ "${lead}" ]]; then
        new_lines+=("${line}" "${repl}")
        block=1
      elif [[ "${block}" -eq 1 && "${line}" =~ "${tail}" ]]; then
        block=0
        new_lines+=("${line}")
      elif [[ "${block}" -eq 0 ]]; then
        new_lines+=("${line}")
      fi
    done
    print -rl -- "${new_lines[@]}" > "${file}"
  fi
}

# ---------------------------------------------------------------------------
# Hydrate Subcommand
# ---------------------------------------------------------------------------

_usage_hydrate() {
  print -r -- "Usage: df.config hydrate <template> [--config-file <path>] [--config-json <json>] [--output <path>]"
}

cmd_hydrate() {
  local -A opts
  zparseopts -E -D -K -A opts -config-file: -config-json: -output: h -help

  if (( ${+opts[-h]} || ${+opts[--help]} )); then
    _usage_hydrate
    return 0
  fi

  local tpl_in="${1:-}"
  if [[ -z "${tpl_in}" ]]; then
    _usage_hydrate
    return 1
  fi
  shift

  local tpl
  tpl=$(_resolve_path templates "${tpl_in}") || {
    err "Template not found: ${tpl_in}"
    return 1
  }

  local merged='{}'

  # Handle --config-file
  if [[ -n "${opts[--config-file]:-}" ]]; then
    local cfg
    cfg=$(_resolve_path configs "${opts[--config-file]}") || return 1
    merged=$(jq -s '.[0] * .[1]' <<<"${merged}" <"${cfg}")
  fi

  # Handle --config-json
  if [[ -n "${opts[--config-json]:-}" ]]; then
    merged=$(jq -s '.[0] * $n' --argjson n "${opts[--config-json]}" <<<"${merged}")
  fi

  # Resolve secrets in the merged JSON
  local aliases_out
  aliases_out=$(print -r -- "${merged}" | jq -r '.. | strings | select(startswith("{secret:") and endswith("}")) | sub("^{secret:"; "") | sub("}$"; "")' | sort -u)

  if [[ -n "${aliases_out}" ]]; then
    local -a aliases=( ${(f)aliases_out} )
    local secrets_reg=$(_load_secrets_registry)
    local alias_item secret_val
    for alias_item in "${aliases[@]}"; do
      secret_val=$(_resolve_secret_alias "${alias_item}" "${secrets_reg}")
      if [[ -n "${secret_val}" ]]; then
        # Replace the token with the actual secret value
        merged=$(jq --arg a "{secret:${alias_item}}" --arg v "${secret_val}" 'walk(if type == "string" and . == $a then $v else . end)' <<<"${merged}")
      else
        err "Warning: Could not resolve secret: ${alias_item}"
      fi
    done
  fi

  merged=$(jq --arg now "$(TZ=UTC0 strftime "%Y-%m-%dT%H:%M:%SZ" "${EPOCHSECONDS}")" '.secrets |= (. // {}) | .created |= (. // $now)' <<<"${merged}")

  local tmp_dir
  tmp_dir="$(mktemp -d)"

  {
    local tmp_json="${tmp_dir}/config.json"
    print -r -- "${merged}" > "${tmp_json}"
    local -a args=(--missing-key=zero -f "${tpl}" -c "config=file://${tmp_json}?type=application/json")

    # Use gomplate to evaluate the configuration file
    local tmp_gomplate_cfg="${tmp_dir}/gomplate.yaml"
    DF_CONFIG_TPL_IN="${tpl_in}" gomplate -f "${DOTFILES}/assets/configs/gomplate/config.yaml.tmpl" -o "${tmp_gomplate_cfg}"
    args+=(--config "${tmp_gomplate_cfg}")

    if [[ -n "${opts[--output]:-}" ]]; then
      mkdir -p "${opts[--output]:h}"
      gomplate "${args[@]}" > "${opts[--output]}"
    else
      gomplate "${args[@]}"
    fi
  } always {
    rm -rf "${tmp_dir}"
  }
}

# ---------------------------------------------------------------------------
# Symlink Subcommand
# ---------------------------------------------------------------------------

_usage_symlink() {
  print -r -- "Usage: df.config symlink [--contents] [--force] <source> <destination>"
}

_do_symlink() {
  local resolved="$1"
  local dst="$2"

  if [[ -d "${dst}" && ! -L "${dst}" ]]; then
    # We rely on 'opts' from the parent function
    if (( ${+opts[--force]} || ${+opts[-f]} )); then
      rm -rf "${dst}"
    else
      err "Destination is a directory: ${dst}"
      return 1
    fi
  fi

  if [[ -L "${dst}" && "${dst:a:P}" == "${resolved}" ]]; then
    return 0
  fi

  if [[ -e "${dst}" || -L "${dst}" ]]; then
    rm -rf "${dst}"
  fi

  mkdir -p "${dst:h}"
  ln -s "${resolved}" "${dst}"
}

cmd_symlink() {
  local -A opts
  zparseopts -E -D -K -A opts -contents -force f -help h

  if (( ${+opts[-h]} || ${+opts[--help]} )); then
    _usage_symlink
    return 0
  fi

  local src="${1:-}"
  local dst="${2:-}"

  if [[ -z "${src}" || -z "${dst}" ]]; then
    _usage_symlink
    return 1
  fi

  local resolved
  resolved=$(_resolve_path configs "${src}") || {
    err "Source not found: ${src}"
    return 1
  }

  if (( ${+opts[--contents]} )); then
    if [[ ! -d "${resolved}" ]]; then
      err "Source is not a directory: ${resolved}"
      return 1
    fi

    if [[ -L "${dst}" || -f "${dst}" ]]; then
      rm -f "${dst}"
    fi
    mkdir -p "${dst}"

    local item
    for item in "${resolved}"/*(DN); do
      _do_symlink "${item}" "${dst}/${item:t}"
    done
    return 0
  fi

  _do_symlink "${resolved}" "${dst}"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

_usage() {
  print -r -- "Usage: df.config <command> [args...]"
  print -r -- ""
  print -r -- "Commands:"
  print -r -- "  resolve    Resolve a secret alias"
  print -r -- "  block      Replace content between markers in a file"
  print -r -- "  hydrate    Template a file using gomplate and JSON configs"
  print -r -- "  symlink    Symlink configuration files from assets"
}

main() {
  local cmd="${1:-}"

  case "${cmd}" in
    resolve)   shift; cmd_resolve "$@" ;;
    block)     shift; cmd_block "$@" ;;
    hydrate)   shift; cmd_hydrate "$@" ;;
    symlink)   shift; cmd_symlink "$@" ;;
    -h|--help) _usage ;;
    *)
      err "Unknown command: ${cmd:-<none>}"
      _usage >&2
      return 1
      ;;
  esac
}

main "$@"
