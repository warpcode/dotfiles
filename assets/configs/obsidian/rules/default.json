{
  "type": "default",
  "fields": {
    "title": {
      "type": "text"
    },
    "created": {
      "type": "date",
      "format": "YYYY-MM-DDTHH:mm:ssZ"
    },
    "assignee": {
      "type": "select",
      "values_from_attr": [
        "assignee",
        "owner"
      ],
      "is_link": true
    },
    "due": {
      "type": "date",
      "format": "YYYY-MM-DDTHH:mm:ssZ"
    },
    "tags": { 
      "type": "multi-select", 
      "values": ["frontend", "backend", "infra", "bug", "chore", "research", "design", "devops"],
      "values_from_attr": ["tags"],
      "values_allow_custom": true 
    },

    "status": {
      "type": "select",
      "values": [
        "todo",
        "in_progress",
        "done"
      ]
    },
    "description": {
      "type": "text"
    },
    "notes": {
      "type": "text"
    }
  }
}
