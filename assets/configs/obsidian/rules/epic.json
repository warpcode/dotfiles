{
  "type": "epic",
  "folder": "Epics",
  "prompts": [
    { "mode": "one", "fields": ["project"], "label": "Parent" },
    { "mode": "all", "fields": ["status"] },
    { "mode": "optional", "fields": ["description", "tags"] }
  ],
  "fields": {
    "project": { "type": "select", "values_from_note_type": ["project"], "is_link": true },
    "status": { "type": "select", "values": ["planned", "active", "complete", "cancelled"] },
    "description": { "from_type": "default", "from_field": "description" },
    "tags": { "from_type": "default", "from_field": "tags" }
  }
}
