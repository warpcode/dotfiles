{
  "type": "task",
  "folder": "Tasks",
  "prompts": [
    { "mode": "one", "fields": ["epic", "project", "area"], "label": "Parent" },
    { "mode": "all", "fields": ["status", "priority"] },
    { "mode": "optional", "fields": ["assignee", "tags", "description"] }
  ],
  "fields": {
    "priority": { "type": "select", "values": ["low", "medium", "high", "critical"] },
    "epic": { "type": "select", "values_from_note_type": ["epic"], "is_link": true },
    "project": { "type": "select", "values_from_note_type": ["project"], "is_link": true },
    "area": { "type": "select", "values_from_note_type": ["area"], "is_link": true },
    "status": { "type": "select", "values": ["backlog", "in-progress", "blocked", "in-review", "done"] },
    "assignee": { "from_type": "default", "from_field": "assignee" },
    "tags": { "from_type": "default", "from_field": "tags" }
  }
}
