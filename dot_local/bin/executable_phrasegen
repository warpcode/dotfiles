#!/usr/bin/env bash

words="${1:-4}"
delimiter="${2:- }"

# Determine the best available random shuffling tool
if command -v shuf >/dev/null 2>&1; then
    shuffle_cmd=(shuf -n "${words}")
    [[ -e /dev/urandom ]] && shuffle_cmd+=(--random-source=/dev/urandom)
elif command -v gshuf >/dev/null 2>&1; then
    shuffle_cmd=(gshuf -n "${words}")
    [[ -e /dev/urandom ]] && shuffle_cmd+=(--random-source=/dev/urandom)
else
    # Fallback to sort -R if shuf is not available.
    # Note: sort -R is less efficient as it sorts the entire input.
    shuffle_cmd=(sort -R)
fi

exec cat "${XDG_CONFIG_HOME:-${HOME}/.config}"/dotfiles/wordlists/google-10000-english-usa-no-swears-*.txt \
    | "${shuffle_cmd[@]}" \
    | head -n "${words}" \
    | paste -s -d "$delimiter" -
